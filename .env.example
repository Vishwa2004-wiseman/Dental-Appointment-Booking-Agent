# ─────────────────────────────────────────────────────────────
# Dental Booking Agent — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Server ---
PORT=3000
BASE_URL=                      # Railway public URL, e.g. https://your-app.up.railway.app
NODE_ENV=development

# --- Tenant (multi-tenant readiness) ---
CLINIC_ID=demo-clinic-001

# --- Firestore (Firebase service account) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines, wrapped in quotes:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# --- Google Calendar ---
GOOGLE_CALENDAR_ID=            # e.g. primary or the shared calendar id for the clinic
# Optional: full service-account JSON as a single-line string (falls back to FIREBASE_* if unset)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Default appointment length in minutes
APPOINTMENT_DURATION_MINUTES=30
# IANA timezone used when interpreting caller date/time
CLINIC_TIMEZONE=Asia/Kolkata

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=           # e.g. +15005550006

# --- Admin API ---
ADMIN_API_KEY=change-me-please

# --- VAPI (optional signature verification) ---
VAPI_WEBHOOK_SECRET=

# --- Feature flags ---
# When true, external calls (Firestore/Calendar/Twilio) run in mock mode so you can
# test the full flow locally without any credentials. Auto-enabled if creds are missing.
MOCK_MODE=false
